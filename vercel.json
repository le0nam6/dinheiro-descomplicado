{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "functions": {
    "src/app/api/cron/edition/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/edition-candidates/route.ts": { "maxDuration": 120 },
    "src/app/api/cron/edition-watchdog/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/news/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/publish/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/ig-backlog/route.ts": { "maxDuration": 120 },
    "src/app/api/cron/weekly-insights/route.ts": { "maxDuration": 300 }
  },
  "crons": [
    { "path": "/api/cron/edition-candidates", "schedule": "0 1 * * *" },
    { "path": "/api/cron/edition", "schedule": "0 9 * * *" },
    { "path": "/api/cron/news", "schedule": "0 0-2,9-23 * * *" },
    { "path": "/api/cron/publish", "schedule": "0 12,15,18,21 * * *" },
    { "path": "/api/cron/ig-backlog", "schedule": "0 13,17,20,23 * * *" }
  ]
}
